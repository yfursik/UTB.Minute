@page "/my-orders"
@using UTB.Minute.Contracts
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Student")]
@inject IHttpClientFactory ClientFactory
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>My Orders</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">📋 My Orders</h2>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error!</strong> @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @if (orders == null)
    {
        <div class="spinner-border text-primary" role="status"></div>
    }
    else if (!orders.Any())
    {
        <div class="alert alert-info">You have no orders yet. Check today's menu to place an order!</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var order in orders.OrderByDescending(o => o.CreatedAt))
            {
                <div class="col">
                    <div class="card shadow-sm border-@(GetStatusColor(order.Status))">
                        <div class="card-header bg-@(GetStatusColor(order.Status)) text-white d-flex justify-content-between">
                            <strong>Order #@order.Id</strong>
                            <span>@order.Status</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@order.MenuItem.Food.Name</h5>
                            <p class="card-text text-muted">Ordered at: @order.CreatedAt.ToLocalTime().ToString("f")</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private OrderDto[]? orders;
    private string? errorMessage;
    private CancellationTokenSource? _sseCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
        _sseCts = new CancellationTokenSource();
        _ = SubscribeToOrderEventsAsync(_sseCts.Token);
    }

    public void Dispose() => _sseCts?.Cancel();

    private async Task SubscribeToOrderEventsAsync(CancellationToken ct)
    {
        try
        {
            using var client = ClientFactory.CreateClient("api-sse");
            using var request = new HttpRequestMessage(HttpMethod.Get, "sse/orders");
            using var response = await client.SendAsync(request, HttpCompletionOption.ResponseHeadersRead, ct);
            response.EnsureSuccessStatusCode();
            await using var stream = await response.Content.ReadAsStreamAsync(ct);
            using var reader = new StreamReader(stream);
            while (!ct.IsCancellationRequested)
            {
                var line = await reader.ReadLineAsync(ct);
                if (line?.StartsWith("data: ") == true)
                {
                    await InvokeAsync(async () =>
                    {
                        await LoadOrders();
                        StateHasChanged();
                    });
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadOrders()
    {
        try
        {
            using var client = ClientFactory.CreateClient("api");
            var response = await client.GetAsync("/orders");
            if (response.IsSuccessStatusCode)
            {
                errorMessage = null;
                orders = await response.Content.ReadFromJsonAsync<OrderDto[]>();
            }
            else
            {
                errorMessage = response.StatusCode == System.Net.HttpStatusCode.Unauthorized
                    ? "Please sign in to see your orders."
                    : "Failed to load orders from server.";
                orders = [];
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Cannot reach the server. Please try again.";
            orders = [];
        }
    }

    private static string GetStatusColor(OrderStatus status) => status switch
    {
        OrderStatus.Preparing => "warning text-dark",
        OrderStatus.Ready => "success",
        OrderStatus.Cancelled => "danger",
        _ => "secondary"
    };
}
