@page "/"
@using UTB.Minute.Contracts
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Student,Cook")]
@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState
@rendermode InteractiveServer

<PageTitle>Today's Menu</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">🍽️ Today's Menu</h2>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error!</strong> @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }

    @if (menuItems == null)
    {
        <div class="spinner-border text-primary" role="status"></div>
    }
    else if (!menuItems.Any())
    {
        <div class="alert alert-info">The menu is empty for today.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in menuItems.OrderBy(m => m.Date))
            {
                var isSoldOut = item.AvailablePortions <= 0;
                <div class="col">
                    <div class="card h-100 shadow-sm @(isSoldOut ? "opacity-75" : "")" style="@(isSoldOut ? "filter: grayscale(0.7); pointer-events: none;" : "")">
                        @if (isSoldOut)
                        {
                            <div class="position-absolute top-0 start-0 end-0 text-center py-2 bg-dark text-white rounded-top">Sold out</div>
                        }
                        <div class="card-body @(isSoldOut ? "pt-5" : "")">
                            <h5 class="card-title">@item.Food.Name</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@item.Date.ToShortDateString()</h6>
                            <p class="card-text">@item.Food.Description</p>
                            <p class="card-text">
                                <strong>Price: </strong> @item.Food.Price CZK <br />
                                <strong>Portions Left: </strong>
                                <span class="badge @(item.AvailablePortions > 0 ? "bg-success" : "bg-secondary")">
                                    @item.AvailablePortions
                                </span>
                            </p>
                        </div>
                        <AuthorizeView Roles="Student">
                            <Authorized>
                                <div class="card-footer bg-white border-top-0">
                                    <button class="btn w-100 @(isSoldOut ? "btn-secondary" : "btn-primary")"
                                            disabled="@isSoldOut"
                                            @onclick="@(() => { if (!isSoldOut) PlaceOrder(item.Id); })">
                                        @(isSoldOut ? "Sold out" : "Order Now")
                                    </button>
                                </div>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private MenuItemDto[]? menuItems;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        if (auth.User.IsInRole("Cook"))
        {
            Navigation.NavigateTo("/orders", forceLoad: true);
            return;
        }
        await LoadMenu();
    }

    private async Task LoadMenu()
    {
        try
        {
            using var client = ClientFactory.CreateClient("api");
            var response = await client.GetAsync("/menu/today");
            if (response.IsSuccessStatusCode)
            {
                errorMessage = null;
                menuItems = await response.Content.ReadFromJsonAsync<MenuItemDto[]>();
            }
            else
            {
                errorMessage = "Failed to load menu from server.";
                menuItems = [];
            }
        }
        catch (HttpRequestException)
        {
            menuItems = [];
        }
    }

    private async Task PlaceOrder(int menuItemId)
    {
        errorMessage = null;
        successMessage = null;
        using var client = ClientFactory.CreateClient("api");
        var dto = new CreateOrderDto(menuItemId);
        var response = await client.PostAsJsonAsync("/orders", dto);

        if (response.IsSuccessStatusCode)
        {
            successMessage = "Your order has been placed successfully!";
            await LoadMenu();
        }
        else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            errorMessage = await response.Content.ReadAsStringAsync();
            await LoadMenu();
        }
        else
        {
            errorMessage = "Failed to place order. It might be sold out.";
        }
    }
}
