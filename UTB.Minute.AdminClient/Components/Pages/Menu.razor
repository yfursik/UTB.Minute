@page "/menu"
@using UTB.Minute.Contracts
@using Microsoft.AspNetCore.Authorization;
@attribute [Authorize(Roles = "Admin")]
@inject IHttpClientFactory ClientFactory
@rendermode InteractiveServer

<PageTitle>Menu Management</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">📅 Menu Management</h2>

    <div class="card mb-4 p-3 bg-light">
        <h4>Copy Menu</h4>
        <p class="text-muted small">Copy all items from one date to another. Items already on the target date are skipped.</p>
        <div class="row g-3 align-items-end mb-2">
            <div class="col-md-4">
                <label class="form-label">From date</label>
                <input type="date" class="form-control" @bind="copyFromDate" />
            </div>
            <div class="col-md-4">
                <label class="form-label">To date</label>
                <input type="date" class="form-control" @bind="copyToDate" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-primary w-100" @onclick="CopyMenu">Copy</button>
            </div>
        </div>
    </div>

    <div class="card mb-4 p-3 bg-light">
        <h4>Add to Menu</h4>
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Date</label>
                <input type="date" class="form-control" @bind="newMenu.Date" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Food</label>
                <select class="form-select" @bind="newMenu.FoodId">
                    <option value="0">-- Select Food --</option>
                    @if (availableFoods != null)
                    {
                        @foreach (var food in availableFoods.Where(f => f.IsActive))
                        {
                            <option value="@food.Id">@food.Name (@food.Price CZK)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Portions</label>
                <input type="number" class="form-control" @bind="newMenu.AvailablePortions" min="1" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" @onclick="CreateMenuItem">Add</button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(authError))
    {
        <div class="alert alert-warning">
            @authError
        </div>
    }
    @if (menuItems == null)
    {
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    }
    else if (!menuItems.Any() && authError == null)
    {
        <div class="alert alert-info">The menu is empty. Add some food to specific dates!</div>
    }
    else
    {
        <table class="table table-hover shadow-sm rounded">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Food</th>
                    <th>Portions Left</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in menuItems.OrderBy(m => m.Date))
                {
                    <tr>
                        <td><strong>@item.Date.ToShortDateString()</strong></td>
                        <td>@item.Food.Name</td>
                        <td>
                            <span class="badge @(item.AvailablePortions > 0 ? "bg-success" : "bg-danger")">
                                @item.AvailablePortions
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditMenuItem(item)">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteMenuItem(item.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (showEditModal && editingItem != null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Menu Item - @editingItem.Food.Name</h5>
                    <button type="button" class="btn-close" @onclick="() => showEditModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" @bind="editDate" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Available Portions</label>
                        <input type="number" class="form-control" @bind="editPortions" min="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showEditModal = false">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveEdit">Save</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private MenuItemDto[]? menuItems;
    private FoodDto[]? availableFoods;
    private string? authError;

    // Снова используем паттерн черновой формы для обхода ошибки CS8852
    private class MenuFormModel
    {
        public DateOnly Date { get; set; } = DateOnly.FromDateTime(DateTime.Now);
        public int FoodId { get; set; }
        public int AvailablePortions { get; set; } = 20;
    }

    private MenuFormModel newMenu = new();

    private DateOnly copyFromDate = DateOnly.FromDateTime(DateTime.Now);
    private DateOnly copyToDate = DateOnly.FromDateTime(DateTime.Now);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            using var client = ClientFactory.CreateClient("api");
            var menuResp = await client.GetAsync("/menu");
            var foodsResp = await client.GetAsync("/foods");
            if (menuResp.IsSuccessStatusCode && foodsResp.IsSuccessStatusCode)
            {
                authError = null;
                menuItems = await menuResp.Content.ReadFromJsonAsync<MenuItemDto[]>();
                availableFoods = await foodsResp.Content.ReadFromJsonAsync<FoodDto[]>();
            }
            else
            {
                authError = "Failed to load menu data from server.";
                menuItems = [];
                availableFoods = [];
            }
        }
        catch (HttpRequestException)
        {
            menuItems = [];
            availableFoods = [];
        }
    }

    private async Task CopyMenu()
    {
        authError = null;
        using var client = ClientFactory.CreateClient("api");
        var dto = new CopyMenuDto(copyFromDate, copyToDate);
        var response = await client.PostAsJsonAsync("/menu/copy", dto);
        if (response.IsSuccessStatusCode)
            await LoadData();
        else
            authError = await response.Content.ReadAsStringAsync() ?? "Failed to copy menu.";
    }

    private async Task CreateMenuItem()
    {
        if (newMenu.FoodId == 0 || newMenu.AvailablePortions <= 0) return;
        authError = null;
        using var client = ClientFactory.CreateClient("api");
        var dto = new CreateMenuItemDto(newMenu.Date, newMenu.FoodId, newMenu.AvailablePortions);
        var response = await client.PostAsJsonAsync("/menu", dto);
        if (response.IsSuccessStatusCode)
        {
            newMenu.FoodId = 0;
            newMenu.AvailablePortions = 20;
            await LoadData();
        }
    }

    private async Task DeleteMenuItem(int id)
    {
        authError = null;
        using var client = ClientFactory.CreateClient("api");
        var response = await client.DeleteAsync($"/menu/{id}");
        if (response.IsSuccessStatusCode)
            await LoadData();
    }

    private bool showEditModal;
    private MenuItemDto? editingItem;
    private DateOnly editDate;
    private int editPortions;

    private void EditMenuItem(MenuItemDto item)
    {
        editingItem = item;
        editDate = item.Date;
        editPortions = item.AvailablePortions;
        showEditModal = true;
    }

    private async Task SaveEdit()
    {
        if (editingItem == null) return;
        authError = null;
        using var client = ClientFactory.CreateClient("api");
        var dto = new UpdateMenuItemDto(editDate, editPortions);
        var response = await client.PutAsJsonAsync($"/menu/{editingItem.Id}", dto);
        if (response.IsSuccessStatusCode)
        {
            showEditModal = false;
            await LoadData();
        }
    }
}