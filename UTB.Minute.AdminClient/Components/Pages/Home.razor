@page "/"
@using UTB.Minute.Contracts
@using Microsoft.AspNetCore.Authorization;
@attribute [Authorize(Roles = "Admin")]
@inject IHttpClientFactory ClientFactory
@rendermode InteractiveServer

<PageTitle>Food Management</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">🍔 Food Management</h2>

    <div class="card mb-4 p-3 bg-light">
        <h4>Add New Food</h4>
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Name</label>
                <input class="form-control" @bind="newFood.Name" placeholder="e.g. Fried cheese" />
            </div>
            <div class="col-md-5">
                <label class="form-label">Description</label>
                <input class="form-control" @bind="newFood.Description" placeholder="Description..." />
            </div>
            <div class="col-md-2">
                <label class="form-label">Price (CZK)</label>
                <input type="number" class="form-control" @bind="newFood.Price" />
            </div>
            <div class="col-md-1">
                <button class="btn btn-primary w-100" @onclick="CreateFood">Add</button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(authError))
    {
        <div class="alert alert-warning">
            @authError
        </div>
    }
    @if (foods == null)
    {
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    }
    else if (!foods.Any() && authError == null)
    {
        <div class="alert alert-warning">No food items found in the database.</div>
    }
    else
    {
        <table class="table table-hover shadow-sm rounded">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var food in foods)
                {
                    <tr>
                        <td>@food.Id</td>
                        <td><strong>@food.Name</strong></td>
                        <td>@food.Description</td>
                        <td>@food.Price CZK</td>
                        <td>
                            @if (food.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td>
                            @if (food.IsActive)
                            {
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditFood(food)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeactivateFood(food)">Deactivate</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-success" @onclick="() => ActivateFood(food)">Activate</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (showEditModal && editingFood != null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Food</h5>
                    <button type="button" class="btn-close" @onclick="() => showEditModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Name</label>
                        <input class="form-control" @bind="editName" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Description</label>
                        <input class="form-control" @bind="editDescription" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Price (CZK)</label>
                        <input type="number" class="form-control" @bind="editPrice" />
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="editActive" @bind="editIsActive" />
                        <label class="form-check-label" for="editActive">Active</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showEditModal = false">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveEdit">Save</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private FoodDto[]? foods;
    private string? authError;
    
    // Создаем изменяемую модель специально для ввода текста на сайте
    private class FoodFormModel
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
    }
    
    private FoodFormModel newFood = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadFoods();
    }

    private async Task LoadFoods()
    {
        authError = null;
        try
        {
            using var client = ClientFactory.CreateClient("api");
            var response = await client.GetAsync("/foods");
            if (response.IsSuccessStatusCode)
            {
                authError = null;
                foods = await response.Content.ReadFromJsonAsync<FoodDto[]>();
            }
            else
            {
                authError = "Failed to load foods from server.";
                foods = [];
            }
        }
        catch (HttpRequestException)
        {
            foods = [];
        }
    }

    private async Task CreateFood()
    {
        if (string.IsNullOrWhiteSpace(newFood.Name) || newFood.Price <= 0) return;
        authError = null;
        using var client = ClientFactory.CreateClient("api");
        var dto = new CreateFoodDto(newFood.Name, newFood.Description, newFood.Price);
        var response = await client.PostAsJsonAsync("/foods", dto);
        if (response.IsSuccessStatusCode)
        {
            newFood = new FoodFormModel();
            await LoadFoods();
        }
    }

    private bool showEditModal;
    private FoodDto? editingFood;
    private string editName = "", editDescription = "";
    private decimal editPrice;
    private bool editIsActive;

    private void EditFood(FoodDto food)
    {
        editingFood = food;
        editName = food.Name;
        editDescription = food.Description;
        editPrice = food.Price;
        editIsActive = food.IsActive;
        showEditModal = true;
    }

    private async Task SaveEdit()
    {
        if (editingFood == null) return;
        authError = null;
        using var client = ClientFactory.CreateClient("api");
        var dto = new UpdateFoodDto(editName, editDescription, editPrice, editIsActive);
        var response = await client.PutAsJsonAsync($"/foods/{editingFood.Id}", dto);
        if (response.IsSuccessStatusCode)
        {
            showEditModal = false;
            await LoadFoods();
        }
    }

    private async Task DeactivateFood(FoodDto food)
    {
        authError = null;
        using var client = ClientFactory.CreateClient("api");
        var dto = new UpdateFoodDto(food.Name, food.Description, food.Price, false);
        var response = await client.PutAsJsonAsync($"/foods/{food.Id}", dto);
        if (response.IsSuccessStatusCode)
            await LoadFoods();
    }

    private async Task ActivateFood(FoodDto food)
    {
        authError = null;
        using var client = ClientFactory.CreateClient("api");
        var dto = new UpdateFoodDto(food.Name, food.Description, food.Price, true);
        var response = await client.PutAsJsonAsync($"/foods/{food.Id}", dto);
        if (response.IsSuccessStatusCode)
            await LoadFoods();
    }
}